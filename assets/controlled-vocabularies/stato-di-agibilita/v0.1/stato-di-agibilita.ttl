#################################################################
#    CONCETTI
#################################################################

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/AGIB>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "AGIBILE"@it;
  skos:prefLabel "HABITABLE"@en;
  skos:definition "Immobile certificato come idoneo all'uso e all'occupazione, conforme alle normative tecniche e di sicurezza vigenti."@it;
  skos:definition "Property certified as suitable for use and occupation, compliant with current technical and safety regulations."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "AGIB";
  skos:notation "AGIB" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/INAG>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "INAGIBILE"@it;
  skos:prefLabel "UNINHABITABLE"@en;
  skos:definition "Immobile non idoneo all'uso per gravi carenze strutturali, impiantistiche o igienico-sanitarie, con divieto di occupazione."@it;
  skos:definition "Property unsuitable for use due to serious structural, plant or health deficiencies, with prohibition of occupation."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "INAG";
  skos:notation "INAG" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/PARZ>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "PARZIALMENTE AGIBILE"@it;
  skos:prefLabel "PARTIALLY HABITABLE"@en;
  skos:definition "Immobile utilizzabile solo per specifici usi o in determinate porzioni, con limitazioni documentate."@it;
  skos:definition "Property usable only for specific uses or in certain portions, with documented limitations."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "PARZ";
  skos:notation "PARZ" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/RISTR>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "IN RISTRUTTURAZIONE"@it;
  skos:prefLabel "UNDER RENOVATION"@en;
  skos:definition "Immobile temporaneamente non utilizzabile a causa di interventi di ristrutturazione, manutenzione straordinaria o adeguamento."@it;
  skos:definition "Property temporarily unusable due to renovation, extraordinary maintenance or adaptation works."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "RISTR";
  skos:notation "RISTR" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/DEGRAD>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "DEGRADATO"@it;
  skos:prefLabel "DETERIORATED"@en;
  skos:definition "Immobile in condizioni di degrado fisico ma non oggetto di ordinanze di inagibilità, richiedente interventi di recupero."@it;
  skos:definition "Property in physical deterioration but not subject to uninhabitability orders, requiring recovery interventions."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "DEGRAD";
  skos:notation "DEGRAD" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/SISM>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "INAGIBILE PER EVENTI SISMICI"@it;
  skos:prefLabel "UNINHABITABLE DUE TO SEISMIC EVENTS"@en;
  skos:definition "Immobile dichiarato temporaneamente o permanentemente inagibile a seguito di danni da eventi sismici."@it;
  skos:definition "Property declared temporarily or permanently uninhabitable following damage from seismic events."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "SISM";
  skos:notation "SISM" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/VERIF>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "IN VERIFICA"@it;
  skos:prefLabel "UNDER ASSESSMENT"@en;
  skos:definition "Immobile in fase di accertamento tecnico dello stato di agibilità, in attesa di certificazione definitiva."@it;
  skos:definition "Property undergoing technical assessment of habitability status, awaiting final certification."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "VERIF";
  skos:notation "VERIF" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/DEMOL>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "DA DEMOLIRE"@it;
  skos:prefLabel "TO BE DEMOLISHED"@en;
  skos:definition "Immobile per cui è stata disposta la demolizione per motivi di sicurezza o urbanistici."@it;
  skos:definition "Property for which demolition has been ordered for safety or urban planning reasons."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "DEMOL";
  skos:notation "DEMOL" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/NUOVA>
  a skos:Concept, :TipoStatoDiAgibilitàImmobile;
  skos:prefLabel "NUOVA COSTRUZIONE"@it;
  skos:prefLabel "NEW CONSTRUCTION"@en;
  skos:definition "Immobile di nuova edificazione in attesa di prima certificazione di agibilità."@it;
  skos:definition "Newly built property awaiting first habitability certification."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>;
  dct:identifier "NUOVA";
  skos:notation "NUOVA" .
