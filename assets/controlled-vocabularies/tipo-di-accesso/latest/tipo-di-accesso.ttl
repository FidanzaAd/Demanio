#################################################################
#    CONCETTI
#################################################################

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/PUBB>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO PUBBLICO"@it;
  skos:prefLabel "PUBLIC ACCESS"@en;
  skos:definition "Immobile liberamente accessibile al pubblico senza necessità di autorizzazioni o limitazioni, nel rispetto degli orari e delle modalità stabilite."@it;
  skos:definition "Property freely accessible to the public without the need for authorization or restrictions, in compliance with established schedules and procedures."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "PUBB";
  skos:notation "PUBB" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/RISV>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO RISERVATO"@it;
  skos:prefLabel "RESTRICTED ACCESS"@en;
  skos:definition "Immobile accessibile solo a personale autorizzato o a soggetti specificamente abilitati, con controlli all'ingresso."@it;
  skos:definition "Property accessible only to authorized personnel or specifically qualified persons, with entry controls."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "RISV";
  skos:notation "RISV" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/REGOL>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO REGOLAMENTATO"@it;
  skos:prefLabel "REGULATED ACCESS"@en;
  skos:definition "Immobile accessibile previo rispetto di specifiche condizioni, procedure o requisiti documentali (prenotazione, biglietto, registrazione)."@it;
  skos:definition "Property accessible upon compliance with specific conditions, procedures or documentary requirements (booking, ticket, registration)."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "REGOL";
  skos:notation "REGOL" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/COND>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO CONDIZIONATO"@it;
  skos:prefLabel "CONDITIONAL ACCESS"@en;
  skos:definition "Immobile accessibile solo in presenza di determinate condizioni temporali, eventi o circostanze specifiche."@it;
  skos:definition "Property accessible only in the presence of certain temporal conditions, events or specific circumstances."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "COND";
  skos:notation "COND" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/PRIV>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO PRIVATO"@it;
  skos:prefLabel "PRIVATE ACCESS"@en;
  skos:definition "Immobile a uso esclusivo, non accessibile al pubblico, riservato a specifici utenti o funzioni."@it;
  skos:definition "Property for exclusive use, not accessible to the public, reserved for specific users or functions."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "PRIV";
  skos:notation "PRIV" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/GUIDATO>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO GUIDATO"@it;
  skos:prefLabel "GUIDED ACCESS"@en;
  skos:definition "Immobile accessibile esclusivamente tramite visite guidate o accompagnamento di personale autorizzato."@it;
  skos:definition "Property accessible exclusively through guided tours or accompaniment by authorized personnel."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "GUIDATO";
  skos:notation "GUIDATO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/ORARIO>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO CON ORARIO"@it;
  skos:prefLabel "SCHEDULED ACCESS"@en;
  skos:definition "Immobile accessibile solo in specifiche fasce orarie predeterminate e comunicate al pubblico."@it;
  skos:definition "Property accessible only during specific predetermined time slots communicated to the public."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "ORARIO";
  skos:notation "ORARIO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/EVENTO>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO PER EVENTI"@it;
  skos:prefLabel "EVENT ACCESS"@en;
  skos:definition "Immobile accessibile solo in occasione di eventi, manifestazioni o iniziative specifiche."@it;
  skos:definition "Property accessible only on the occasion of specific events, demonstrations or initiatives."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "EVENTO";
  skos:notation "EVENTO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/EMERG>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO DI EMERGENZA"@it;
  skos:prefLabel "EMERGENCY ACCESS"@en;
  skos:definition "Immobile con accesso consentito solo per motivi di emergenza, sicurezza o interventi urgenti."@it;
  skos:definition "Property with access allowed only for emergency reasons, security or urgent interventions."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "EMERG";
  skos:notation "EMERG" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/BARR>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO CON BARRIERE"@it;
  skos:prefLabel "BARRIER ACCESS"@en;
  skos:definition "Immobile con presenza di barriere architettoniche che limitano o condizionano l'accessibilità."@it;
  skos:definition "Property with architectural barriers that limit or condition accessibility."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "BARR";
  skos:notation "BARR" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDiAccesso/UNIV>
  a skos:Concept, :TipoDiAccessoImmobile;
  skos:prefLabel "ACCESSO UNIVERSALE"@it;
  skos:prefLabel "UNIVERSAL ACCESS"@en;
  skos:definition "Immobile progettato o adattato per garantire piena accessibilità a tutti, incluse persone con disabilità."@it;
  skos:definition "Property designed or adapted to ensure full accessibility to all, including people with disabilities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>;
  dct:identifier "UNIV";
  skos:notation "UNIV" .
