<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>
  rdf:type skos:ConceptScheme , adms:Asset , dcatapit:Dataset ;
  dct:title "Vocabolario Controllato delle Destinazioni d'Uso"@it, "Controlled Vocabulary for Intended Use"@en ;
  dct:description "La destinazione d'uso rappresenta la classificazione funzionale degli immobili gestiti dall'Agenzia del Demanio, indicando la tipologia di utilizzo prevalente o previsto per ciascun bene. Tale classificazione consente di identificare l'impiego effettivo o potenziale degli spazi, distinguendo tra destinazioni residenziali, commerciali, istituzionali, culturali o di altra natura, in conformità alla normativa urbanistica e alle finalità pubbliche."@it, "The intended use represents the functional classification of properties managed by the State Property Agency, indicating the main or planned type of use for each asset. This classification allows for the identification of the actual or potential use of spaces, distinguishing between residential, commercial, institutional, cultural, or other uses, in accordance with urban planning regulations and public purposes."@en ;
  xkos:numberOfLevels "1" ;
  dct:type <http://purl.org/adms/assettype/CodeList> ;
  adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
  dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso";
  dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
  dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
  dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
  dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
  dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
  dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
  rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso> ;
  dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dcat:keyword "Destinazione d'Uso"@it, "Intended Use"@en ;
  dcat:distribution <https://w3id.org/italia/data/distribution/destinazione-di-uso-RDF-Turtle> ,
