                     <https://w3id.org/italia/data/distribution/stato-di-agibilita-JSON-LD> ;
  dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
  dct:issued "2026-02-18"^^xsd:date ;
  dct:modified "2026-02-18"^^xsd:date ;
  owl:versionInfo "Versione 0.1"@it ;
  ndc:keyConcept "stato-di-agibilita" ;
  skos:hasTopConcept <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/AGIB> ,
                        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoStatoDiAgibilita/INAG> ,
