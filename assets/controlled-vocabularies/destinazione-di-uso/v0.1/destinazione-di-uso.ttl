#################################################################
#    CONCETTI
#################################################################

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/RES>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "RESIDENZIALE"@it;
  skos:prefLabel "RESIDENTIAL"@en;
  skos:definition "Immobile destinato ad abitazione civile e a servizi connessi alla residenza."@it;
  skos:definition "Property intended for residential housing and related services."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "RES";
  skos:notation "RES" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/COM>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "COMMERCIALE"@it;
  skos:prefLabel "COMMERCIAL"@en;
  skos:definition "Immobile destinato ad attività commerciali, di vendita al dettaglio o all'ingrosso."@it;
  skos:definition "Property intended for commercial activities, retail or wholesale."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "COM";
  skos:notation "COM" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/UFF>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "UFFICI"@it;
  skos:prefLabel "OFFICES"@en;
  skos:definition "Immobile destinato ad attività amministrative, direzionali e professionali."@it;
  skos:definition "Property intended for administrative, management and professional activities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "UFF";
  skos:notation "UFF" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/IND>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "INDUSTRIALE"@it;
  skos:prefLabel "INDUSTRIAL"@en;
  skos:definition "Immobile destinato ad attività produttive, manifatturiere o artigianali."@it;
  skos:definition "Property intended for production, manufacturing or craft activities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "IND";
  skos:notation "IND" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/CUL>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "CULTURALE"@it;
  skos:prefLabel "CULTURAL"@en;
  skos:definition "Immobile destinato ad attività culturali, museali, bibliotecarie o di spettacolo."@it;
  skos:definition "Property intended for cultural, museum, library or entertainment activities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "CUL";
  skos:notation "CUL" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/IST>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "ISTITUZIONALE"@it;
  skos:prefLabel "INSTITUTIONAL"@en;
  skos:definition "Immobile destinato a funzioni pubbliche, amministrative o di servizio pubblico."@it;
  skos:definition "Property intended for public, administrative or public service functions."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "IST";
  skos:notation "IST" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/SAN>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "SANITARIO"@it;
  skos:prefLabel "HEALTHCARE"@en;
  skos:definition "Immobile destinato a strutture sanitarie, assistenziali o socio-sanitarie."@it;
  skos:definition "Property intended for healthcare, care or social-health facilities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "SAN";
  skos:notation "SAN" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/SCO>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "SCOLASTICO"@it;
  skos:prefLabel "EDUCATIONAL"@en;
  skos:definition "Immobile destinato a istruzione, formazione e attività educative."@it;
  skos:definition "Property intended for education, training and educational activities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "SCO";
  skos:notation "SCO" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/DEP>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "DEPOSITO/MAGAZZINO"@it;
  skos:prefLabel "STORAGE/WAREHOUSE"@en;
  skos:definition "Immobile destinato allo stoccaggio, deposito merci o logistica."@it;
  skos:definition "Property intended for storage, goods warehousing or logistics."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "DEP";
  skos:notation "DEP" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/TipoDestinazioneDiUso/AGR>
  a skos:Concept, :TipoDestinazioneDiUsoImmobile;
  skos:prefLabel "AGRICOLO"@it;
  skos:prefLabel "AGRICULTURAL"@en;
  skos:definition "Immobile destinato ad attività agricole, zootecniche o agrituristiche."@it;
  skos:definition "Property intended for agricultural, livestock or agritourism activities."@en;
  skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/destinazione-di-uso>;
  dct:identifier "AGR";
  skos:notation "AGR" .
