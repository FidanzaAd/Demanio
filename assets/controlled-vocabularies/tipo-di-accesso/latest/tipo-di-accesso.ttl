<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso>
  rdf:type skos:ConceptScheme , adms:Asset , dcatapit:Dataset ;
  dct:title "Vocabolario Controllato dei Tipi di Accesso"@it, "Controlled Vocabulary for Access Types"@en ;
  dct:description "Il tipo di accesso rappresenta la modalità con cui è consentito l'ingresso e l'utilizzo degli immobili gestiti dall'Agenzia del Demanio. Tale classificazione identifica il regime di accessibilità fisica e giuridica, distinguendo tra accesso pubblico, riservato, regolamentato o condizionato, in conformità alle normative sulla fruizione del patrimonio pubblico e alle esigenze di sicurezza, tutela e gestione degli spazi."@it, "The access type represents the manner in which entry and use of properties managed by the State Property Agency is permitted. This classification identifies the physical and legal accessibility regime, distinguishing between public, reserved, regulated or conditional access, in accordance with regulations on the use of public assets and security, protection and space management needs."@en ;
  xkos:numberOfLevels "1" ;
  dct:type <http://purl.org/adms/assettype/CodeList> ;
  adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
  dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso";
  dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
  dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
  dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
  dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
  dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
  dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
  rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/tipo-di-accesso> ;
  dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dcat:keyword "Tipo di Accesso"@it, "Access Type"@en ;
  dcat:distribution <https://w3id.org/italia/data/distribution/tipo-di-accesso-RDF-Turtle> ,
