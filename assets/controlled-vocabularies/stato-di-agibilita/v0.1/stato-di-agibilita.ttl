<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita>
  rdf:type skos:ConceptScheme , adms:Asset , dcatapit:Dataset ;
  dct:title "Vocabolario Controllato degli Stati di Agibilità"@it, "Controlled Vocabulary for Habitability Status"@en ;
  dct:description "Lo stato di agibilità rappresenta la condizione tecnica e normativa di un immobile in relazione alla sua idoneità all'uso e all'occupazione. Tale classificazione identifica se l'immobile può essere utilizzato in sicurezza per la destinazione d'uso prevista, sulla base di valutazioni strutturali, impiantistiche e igienico-sanitarie, nonché della conformità alle normative vigenti in materia edilizia e di sicurezza."@it, "The habitability status represents the technical and regulatory condition of a property in relation to its suitability for use and occupation. This classification identifies whether the property can be safely used for its intended purpose, based on structural, plant and health assessments, as well as compliance with current building and safety regulations."@en ;
  xkos:numberOfLevels "1" ;
  dct:type <http://purl.org/adms/assettype/CodeList> ;
  adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
  dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita";
  dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
  dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
  dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
  dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
  dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
  dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
  rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/stato-di-agibilita> ;
  dct:subject <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
  dcat:keyword "Stato di Agibilità"@it, "Habitability Status"@en ;
  dcat:distribution <https://w3id.org/italia/data/distribution/stato-di-agibilita-RDF-Turtle> ,
                     <https://w3id.org/italia/data/distribution/stato-di-agibilita-CSV> ,
